1:05:09.329696","evidence_links":[{"id":"32ea103f-3e3e-4b13-8630-36344f744549:7107222e-57bd-4ba5-bbdf-c213f2af2451","contact_point_id":"32ea103f-3e3e-4b13-8630-36344f744549","source_document_id":"7107222e-57bd-4ba5-bbdf-c213f2af2451","source_url":"https://hbinvest.hu/?page_id=121","title":"hbinvest - Egészségügy","observed_at":"2026-07-17T02:03:33.950931","exact_quote":"info@hbmfu.hu","prefix_text":"4024 Debrecen, Piac u. 54.\n+36 52 507 539\n","suffix_text":"\nAhol jó élni, ahol jó lenni!\nhbinvest.hu\nEgészségügy\nHB megye lakosságának 2018. évre jellemző egészségi állapota\nDemográfia\nHajdú-Bihar megye lakosságát 2000-ben és 2018-ban is a szabálytalan kormegoszlást kifejező korfa jellemezte (1. ábra), mely szerint a gyermekkorú (0-10 évesek), a fiatal középkorú (30-35 évesek), valamint a 80 évesnél idősebb népesség létszáma volt alacsony. A vizsgált időszakban a népesség korösszetételében nőtt az idősek és csökkent a fiatalok aránya. A megye népességének korcsoport szerinti megoszlása alapján a fiatalkorúak (0-14 évesek) és az idősek (65 év felettiek) részaránya megközelítőleg azonos mértékű (15%, illetve 17,7%). A munkaképes korosztály (15-64 évesek) részaránya a legnagyobb (67,3%).\n1\n. ábra: Hajdú-Bihar megye népességének száma nemek és életkor szerint 2000. és 2018. január 1-jén\nA népesség na","char_start":42,"char_end":55,"evidence_kind":"retained_text_exact_match","open_url":"https://hbinvest.hu/?page_id=121","raw_html_path":"sources/raw_html/hu/eade720b4bb0221b1664e33ebd920d37f692555965aa77ceb5e4ece38dd023bf.html","review_text_path":"sources/review_text/7107222e-57bd-4ba5-bbdf-c213f2af2451.txt","screenshot_path":null,"presentation_kind":"archived_html"},{"id":"32ea103f-3e3e-4b13-8630-36344f744549:8282d1ee-4479-45e6-a428-b6d62a3de268","contact_point_id":"32ea103f-3e3e-4b13-8630-36344f744549","source_document_id":"8282d1ee-4479-45e6-a428-b6d62a3de268","source_url":"https://hbinvest.hu/?page_id=113","title":"hbinvest - Elérhetőség","observed_at":"2026-07-17T02:03:44.691213","exact_quote":"info@hbmfu.hu","prefix_text":"4024 Debrecen, Piac u. 54.\n+36 52 507 539\n","suffix_text":"\nAhol jó élni, ahol jó lenni!\nhbinvest.hu\nElérhetőség\nA megye adottságai közt első helyen a fekvése emelendő ki, mivel az ország keleti felén a határ mentén, lényegében sík vidéken, extrém időjárási vagy domborzati szélsőségektől mentesen helyezkedik el. Bár természetes vizek vannak a megyében, akár ipari célú hasznosításra alkalmasan, de a létesítményeket fenyegető árvizektől nem kell tartani. A megye megközelíthetősége regionális összehasonlításban is kiváló, hiszen közvetlen kapcsolat van az európai autópályahálózathoz (és egyre bővül a hossz, javul az elérhetősége a településeknek), a legfőbb vasúti vonal a TEN hálózat része (miközben számos településhez vezet vasútvonal), és légi úton is kiemelkedően jól megközelíthetik a potenciális befektetők a megyét a Debrecen Airporton landoló egyre bővülő számú menetrendszerinti járatokon. A kö","char_start":42,"char_end":55,"evidence_kind":"retained_text_exact_match","open_url":"https://hbinvest.hu/?page_id=113","raw_html_path":"sources/raw_html/hu/a9cab05c4ce779292b615566dbe3f6296b8af7925c7291af1ed7e9d4114bbd51.html","review_text_path":"sources/review_text/8282d1ee-4479-45e6-a428-b6d62a3de268.txt","screenshot_path":null,"presentation_kind":"archived_html"}],"triage":null}],"professionals":[],"sources":[{"url":"https://www.hazipatika.com/tarsadalom/egeszsegugy/cikkek/ennyi_haziorvos_hianyzik_az_orszagbol","domain":"hazipatika.com","source_type":"healthcare_directory","source_role":"directory","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://alapellatas.okfo.gov.hu/idoszakosfelhivasnyilatkozat/","domain":"alapellatas.okfo.gov.hu","source_type":"government_listing","source_role":"government","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":fa