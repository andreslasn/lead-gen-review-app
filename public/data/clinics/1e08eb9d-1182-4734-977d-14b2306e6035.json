 helyzetben vannak például Györgytarló, Putnok, Tiszabő és Mezőhék lakosai, akik 13 éve várna","char_start":1247,"char_end":1257,"evidence_kind":"retained_text_exact_match","open_url":"https://24.hu/belfold/2017/08/30/egyre-tobb-helyen-nincs-haziorvos/"}]}],"professionals":[],"sources":[{"url":"https://www.hazipatika.com/tarsadalom/egeszsegugy/cikkek/ennyi_haziorvos_hianyzik_az_orszagbol","domain":"hazipatika.com","source_type":"healthcare_directory","source_role":"directory","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://alapellatas.okfo.gov.hu/tajekoztato-a-tartosan-betoltetlen-haziorvosi-korzetekrol/","domain":"alapellatas.okfo.gov.hu","source_type":"government_listing","source_role":"government","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://www.neak.gov.hu/pfile/file?path=/letoltheto/altfin_dok/szerzodott_szolgaltatok/Betoltetlen_haziorvosi_szolgalatok&inline=true","domain":"neak.gov.hu","source_type":"government_listing","source_role":"government","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://hovege.hu/maradj-egeszseges/2024/10/29/tartosan-betoltetlen-haziorvosi-praxisok-2024/","domain":"hovege.hu","source_type":"provider_domain_candidate","source_role":"official_candidate","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://mezohek.hu/wp-content/uploads/2025/03/eloterjesztes-haziorvosi-ellatas.pdf","domain":"mezohek.hu","source_type":"provider_domain_candidate","source_role":"official_candidate","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":fals