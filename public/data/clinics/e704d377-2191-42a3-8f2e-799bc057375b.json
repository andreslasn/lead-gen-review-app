 megismerését követően személyre szabott","char_start":920,"char_end":936,"evidence_kind":"retained_text_exact_match","open_url":"https://drtacstimea.hu/","raw_html_path":null,"review_text_path":null,"screenshot_path":null,"presentation_kind":"evidence_excerpt"}],"triage":null}],"professionals":[],"sources":[{"url":"https://foglaljorvost.hu/haziorvosok/dr-szolyka-timea/","domain":"foglaljorvost.hu","source_type":"booking_platform","source_role":"booking","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://foglaljorvost.hu/haziorvosok/s/","domain":"foglaljorvost.hu","source_type":"booking_platform","source_role":"booking","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://doki.hu/orvos/dr-szolyka-timea-budapest-viii-kerulet-983","domain":"doki.hu","source_type":"healthcare_directory","source_role":"directory","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://medgo.hu/item/felnott-haziorvos/budapest-viii-kerulet/dr-szolyka-timea/3083","domain":"medgo.hu","source_type":"healthcare_directory","source_role":"directory","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://medgo.hu/list/Feln%C5%91tt-h%C3%A1ziorvos/Budapest-VIII.-ker%C3%BClet/0/1/897?page=3","domain":"medgo.hu","source_type":"healthcare_directory","source_role":"directory","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://mtaki.hu/orvos/dr-szolyka-timea-budapest-viii-kerulet-983","domain":"mtaki.hu","source_type":"healthcare_dire