ti rendelőintézetet. A településen a fekvőbeteg-ellátás hiányzik, a járóbeteg-szakrendelések, s az ügyelet három helyen volt elérhető. A húszéves Kálvin téri rendelőintézetben nem volt lift, a tető beázott. 2006-ban –pályázati keretek között- sikerült megvalósítani a felvonó létesítését és a tető felújítását, de az elavult orvosi eszközök cseréjére akkor nem nyílt lehetőség.\nA szerkezetileg és berendezésileg elavult épületet a 2010.","char_start":145,"char_end":176,"evidence_kind":"retained_text_exact_match","open_url":"https://hajduboszormeny.hu/intezmenyek/27","raw_html_path":null,"review_text_path":"sources/review_text/60491f31-eba1-4be2-9463-5d27dd912782.txt","screenshot_path":null,"presentation_kind":"text_fallback"}],"triage":null}],"professionals":[{"id":"8f220cb0-eb9f-4c7d-8338-f78f104eaeea","name":"Dr. Béres Katalin","role":"general_practitioner","raw_title":"Dr.","email":null,"phone":"+3652220027","profile_url":null,"confidence":0.96,"bio":null}],"sources":[{"url":"https://doki.hu/orvos/dr-beres-katalin-hajduboszormeny-2981","domain":"doki.hu","source_type":"healthcare_directory","source_role":"directory","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://medgo.hu/item/felnott-haziorvos/hajduboszormeny/dr-beres-katalin/1306","domain":"medgo.hu","source_type":"healthcare_directory","source_role":"directory","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://mtaki.hu/orvos/dr-beres-katalin-hajduboszormeny-2981","domain":"mtaki.hu","source_type":"healthcare_directory","source_role":"directory","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":"Domain mtaki.hu has 1042 recent failed or non-actionable attempts and no useful clinic co