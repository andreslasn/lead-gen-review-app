arkavár\nMiskolc - Leányvár\nSzécsény - Vár - Városerődítés\nSzécsény - Strázsapart (Strázsa-domb)\nSüvéte - Szent Margit körtemplom\nRimabánya - Erődített templom\nÁrvaváralja - Árva vára\nFelsőlehota - Abaffy-kastélyok\nLakács - Lakácsy-kastély - Sándor-várkastély\nGörgő - Görgey erődített udvarház, Csáky-kastély\nGörgő - Szent Simon és Júdás apostolok templom\nŐrimagyarósd - Kastélypart\nZalaszentgrót - Kisszentgrót, Csonka torony (Romtorony)\nZalaszentgrót - Szentgrót vára - Batthyány kastély\nRépceszentgyörgy - Óvár és kastély\nFelsőgöd - Várdomb\nSt. Paul im Lavanttal - Rabenstein ","char_start":752,"char_end":765,"evidence_kind":"retained_text_exact_match","open_url":"https://varak.hu/kapcsolat","raw_html_path":"sources/raw_html/hu/bbf6c73981c2835c810dd5e98872261f443001af80f6c55e8a283e673fb04aa1.html","review_text_path":"sources/review_text/f1bd4214-4c2c-4e04-95ff-e92e1a10bc33.txt","screenshot_path":null,"presentation_kind":"archived_html"}],"triage":null}],"professionals":[],"sources":[{"url":"https://alapellatas.okfo.gov.hu/tajekoztato-a-tartosan-betoltetlen-haziorvosi-korzetekrol/","domain":"alapellatas.okfo.gov.hu","source_type":"government_listing","source_role":"government","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"https://www.neak.gov.hu/pfile/file?path=/letoltheto/altfin_dok/szerzodott_szolgaltatok/Betoltetlen_haziorvosi_szolgalatok&inline=true","domain":"neak.gov.hu","source_type":"government_listing","source_role":"government","ownership_status":"unverified","ownership_confidence":0.0,"useful":false,"has_email":false,"has_phone":false,"has_patient_channel":false,"reason":null},{"url":"http://hellodelsomogy.hu/2015/06/22/betoltetlen-haziorvosi-praxisok-somogyban/","domain":"hellodelsomogy.hu","source_type":"provider_domain_candidate","source_role":"official_candidate","ownership_status":"unverified","ownership_confidence":0.0,"useful