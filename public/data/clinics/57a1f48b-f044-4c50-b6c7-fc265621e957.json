{"schema_version":1,"clinic":{"id":"57a1f48b-f044-4c50-b6c7-fc265621e957","name":"Dr. Takács Györgyi — háziorvosi praxis","legal_name":"PÉCEL Med Kft","registry_id":"130091209","country":"HU","city":"Pécel","region":"PEST","postal_code":"2119","address":"2119, Pécel, Kölcsey u.6.","address_raw":"2119, Pécel, Kölcsey u.6.","address_canonical":"2119, Pécel, Kölcsey u.6.","address_key":"HU:2119:pecel:kolcsey:utca:6","phone":"+3628738880","phone_raw":"+3628738880","website":"https://pecelmed.hu/","domain":"pecelmed.hu","official_website":"https://pecelmed.hu/","official_domain":"pecelmed.hu","official_website_confidence":1.0,"clinic_type":"mixed_primary_care","funding":"mixed","lead_score":56,"contactability_score":55,"data_quality_score":85,"scrape_difficulty_score":44,"source_coverage_status":"verified_official","identity_status":"registry_seeded","identity_confidence":0.95,"outreach_eligibility":"review"},"state":{"clinic_id":"57a1f48b-f044-4c50-b6c7-fc265621e957","status":"needs_review","version":0},"machine_status":"usable_candidate","candidates":[{"id":"e8586b19-f8da-4332-a909-2d672faf4263","value":"info@pecelmed.hu","raw_value":"info@pecelmed.hu","candidate_variants":["info@pecelmed.hu"],"classification":"generic_clinic","usable_contact":true,"confidence":0.95,"owner_name":"Pécel Med Kft","owner_type":"clinic","contact_role":"general_info","associated_role":"háziorvos","association_type":"clinic_contact","verification_status":"source_only","outreach_eligibility":"unknown","syntax_status":"unknown","mx_status":"unknown","deliverability_status":"unknown","source_url":"https://pecelmed.hu/","evidence":"Rendelő elérhetőség: +36 28 738-880, info@pecelmed.hu","reason":"Generic clinic mailbox.","page_context":["homepage","háziorvosi rendelés","rendelő elérhetőség","szűrőprogram felhívás"],"observed_at":"2026-07-14T22:36:03.819508","evidence_links":[{"id":"e8586b19-f8da-4332-a909-2d672faf4263:1b9b03d9-e113-411c-adc7-7c360aad9dbf","contact_point_id":"e8586b19-f8da-4332-a909-2d672faf4263","source_document_id":"1b9b03d9-e113-411c-adc7-7c360aad9dbf","source_url":"https://pecelmed.hu/","title":"Pécel Med Kft Orvosi rendelő, magánrendelések","observed_at":"2026-07-16T08:58:57.660873","exact_quote":"info@pecelmed.hu","prefix_text":"si rendelés Pécelen\nDr. Takács Györgyi\ncsaládorvos, belgyógyász, INSUMED tanácsadó orvos,\nfoglalkozás egészségügyi szakorvos\n2119 Pécel, Kölcsey u 6.\nRendelő elérhetőség:\n+36 28 738-880  Telefon:  +36 20 996-7255\nAz Országos Egészségbiztosítói Pénztár szerződtet  szakorvost  a helyi önkormányzat jóváhagyásával, valamint az ÁNTSZ engedélyezésével együtt egy adott lakóterület (\nlásd ellátási területi utcajegyzék\n) biztosított  lakosságának ellátásra.\nAz NEAK finanszírozza az ellátást, melyért a betegnek fizetnie nem kell. A biztosító a páciensek alapellátását,  gyógyító, megelőző, felvilágosító tevékenységét várja el és fedezi.\nCsaládorvosi RENDELÉSI IDŐ\nhétfő: 9-13 óra\nkedd: 14-18 óra\nszerda: 8 -13 óra (8-9 óráig csak vérvétel előjegyzés alapján)\ncsütörtök: 14-18 óra\npéntek: páros héten: 14-18 óra,\npáratlan héten: 9-13 óra\n+36 28 738-880,\n","suffix_text":"\nTisztelt Pácienseink!\nDr. Takács Györgyi – 2026. 07. 10-től – 2026. 07. 17-ig szabadságon van.\nHelyettesítés akut esetben – előzetes telefonos egyeztetés után:\nDr. Varga Ágnes\na saját rendelési idejében, Pesti út – Orvosi rendelő.\nTelefonszám: +36 28 547-236 / 5 mellék\nEgyéb adminisztráció, ügyintézés továbbra is a rendelőben, például gyógyszer igénylések, betegség igazolása, vérvétel a saját rendelőben történik.: +36 28 738-880\nKöszönettel:\nOnline előjegyzés\nA háziorvosi rendelés néhány óráját a továbbiakban csak előjegyzésre tartjuk fent.\nKérjük az alábbi gombra kattintva jelentkezzen be rendelésünkre!\nElőjegyzésre jelentkezem\n>> Családorvosi rendelés oldalra\nBelgyógyászati magánrendelés Pécelen\nMagánrendelésemen a betegek minimális várakozással, magas színvonalon legyenek ellátva és minden kérdésükre is választ kapnak.\nMagánrendelések","char_start":1353,"char_end":1369,"evidence_kind":"retained_text_exact_match","open_url":"https://pecelmed.hu/","raw_html_path":"sources/raw_html/hu/f9c4f390e5b89af0f1cd4fa26f4c3532a5125e6c2606be68c04516c3adb0dc44.html","review_text_path":"sources/review_text/1b9b03d9-e113-411c-adc7-7c360aad9dbf.txt","screenshot_path":"sources/screenshots/hu/070cc6355d51e0e06554f3cf36909a0aba8ee03aa89d65670015cb88eeabb4fb.jpeg"}],"triage":null},{"id":"35754e11-71bb-47b8-8a93-234fc495e48f","value":"csepe.katalin@epc-honvedkorhaz.hu","raw_value":"d7b4a4b2a7b2f9bcb6a3b6bbbeb997b2a7b4fabfb8b9a1b2b3bcb8a5bfb6adf9bfa2","candidate_variants":["csepe.katalin@epc-honvedkorhaz.hu"],"classification":"unknown","usable_contact":false,"confidence":0.9,"owner_name":"pecel.hu","owner_type":"unknown","contact_role":"unknown","associated_role":null,"association_type":"unverified","verification_status":"conflicting","outreach_eligibility":"review","syntax_status":"unknown","mx_status":"unknown","deliverability_status":"unknown","source_url":"https://pecel.hu/hirek/haziorvos-szabadsag-dr-takacs-gyorgyi-1267","evidence":"4. védőnői körzet: Csépe Katalin Telefon: 06-30-509-4757 E-mail: [email protected]","reason":"Email was found on a supporting/directory source but could not be reliably matched to the target registry clinic. Needs review due to low confidence or conflicting target evidence. Triage llm-v1: different_provider (0.99).","page_context":["page"],"observed_at":"2026-07-14T22:36:03.820075","evidence_links":[{"id":"35754e11-71bb-47b8-8a93-234fc495e48f:fallback","contact_point_id":"35754e11-71bb-47b8-8a93-234fc495e48f","source_document_id":null,"source_url":"https://pecel.hu/hirek/haziorvos-szabadsag-dr-takacs-gyorgyi-1267","title":null,"observed_at":"2026-07-14T22:36:03.820075","exact_quote":"csepe.katalin@epc-honvedkorhaz.hu","prefix_text":"","suffix_text":"4. védőnői körzet: Csépe Katalin Telefon: 06-30-509-4757 E-mail: [email protected]","char_start":null,"char_end":null,"evidenc