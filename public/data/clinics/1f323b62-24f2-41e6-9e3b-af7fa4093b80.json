4 tartósan betöltetlen Magyarországon a Nemzeti Egészségbiztosítási Alapkezelő adatai szerint - írta hétfői lapszámában a Világgazdaság.\nA legtöbb háziorvos Nógrád, Borsod-Abaúj-Zemplén, Békés, Somogy és Tolna megyéből hiányzik, ezekben a megyékben 10 százalék felett van a betöltetlen praxiso","char_start":1396,"char_end":1412,"evidence_kind":"retained_text_exact_match","open_url":"https://444.hu/2017/05/29/a-praktizalo-magyar-haziorvosok-44-szazaleka-elmult-hatvan-11-szazalekuk-pedig-a-hetvenen-is-tul-van"}]},{"id":"00b36b6f-2ef8-49dc-b62f-009c8524119d","value":"info@24.hu","raw_value":"info@24.hu","candidate_variants":[],"classification":"directory_operator","usable_contact":false,"confidence":0.55,"owner_name":"24.hu","owner_type":"directory_operator","contact_role":"general_info","associated_role":null,"association_type":"website_operator","verification_status":"source_only","outreach_eligibility":"review","syntax_status":"unknown","mx_status":"unknown","deliverability_status":"unknown","source_url":"https://24.hu/belfold/2023/02/23/haziorvos-egeszsegugy-betoltetlen-praxisok-magyar-orvosi-kamara/","evidence":"mailto:info@24.hu?Subject=%5B24.hu%5D%20Olvas%C3%B3i%20sztori","reason":"Mailbox belongs to the source operator, not the listed provider.","page_context":["page","directory"],"observed_at":"2026-07-14T21:25:07.498237","evidence_links":[{"id":"00b36b6f-2ef8-49dc-b62f-009c8524119d:6e1d7099-1ef5-4b4a-9b7f-29bf3681fb7f","contact_point_id":"00b36b6f-2ef8-49dc-b62f-009c8524119d","source_document_id":"6e1d7099-1ef5-4b4a-9b7f-29bf3681fb7f","source_url":"https://24.hu/belfold/2023/02/23/haziorvos-egeszsegugy-betoltetlen-praxisok-magyar-orvosi-kamara/","title":"Lakmusz: a hatvan évnél fiatalabb háziorvosok száma megegyezik az ennél idősebbekével | 24.hu","observed_at":"2026-07-14T21:24:54.007883","exact_quote":"info@24.hu","prefix_text":"thor\":[{\"@type\":\"Person\",\"name\":\"Papp Atilla\",\"url\":\"https://24.hu/author/pappa/\"}],\"isAccessibleForFree\":true,\"ma