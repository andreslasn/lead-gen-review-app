oint_id":"33ad5171-0708-461b-be9f-8067c55af694","source_document_id":"5ff9c858-411a-4a3b-9ad4-b06185a797d8","source_url":"https://drszentes.hu/dr-gali-ida/","title":"Dr. Gáli Ida - Dr. Szentes","observed_at":"2026-07-17T00:19:04.386818","exact_quote":"kapcsolat@drszentes.hu","prefix_text":"","suffix_text":"\nOldal kiválasztása\nDr. Gáli Ida\ngyermekorvos\n(társadalombiztosítás terhére igénybe vehető  szolgáltatás)\nDr. Gali Ida házi gyermekorvos vagyok, immár 50 éve a pályán.\nMa már a harmadik generáció jár hozzám, így jól ismerem a családok örömeit és gondjait. Hivatásom a szenvedélyem: szeretettel és legjobb tudásom szerint segítem a kicsiket és nagyokat, ezért a gyerekek bizalommal érkeznek a rendelőbe.\nA szakmaiság mellett az őszinteséget és hitelességet tartom a legfontosabbnak.\nMunkámban kiemelt szerepe van a prevenciónak és a test–lélek egyensúlyának. Mottóm: „A szeretet soha el nem múlik” és „Csak jó ember lehet jó orvos.”\nFelhívom\nBővebben\nBővebb információ\nSzakvizsgáim:\nOrvostudományi Egyetem Általános kar 1976\nCsecsemő és gyermekgyógyászat szakvizsga 1981\nSportorvostan 2008\nTelefon\n:\nCsak rendelési időben!\n☎ 06 63 481 048\n☎ 06 30 229 ","char_start":0,"char_end":22,"evidence_kind":"retained_text_exact_match","open_url":"https://drszentes.hu/dr-gali-ida/","raw_html_path":"sources/raw_html/hu/7846961c338efc2a7aff76b247ff181d24ace7e0c771bf40cb6998c887dc2cf2.html","review_text_path":"sources/review_text/5ff9c858-411a-4a3b-9ad4-b06185a797d8.txt","screenshot_path":null,"presentation_kind":"archived_html"}],"triage":null}],"professionals":[{"id":"397aa754-41d8-452c-8889-82f5e62236ab","name":"Dr. Gali Ida","role":"hazi_gyermekorvos","raw_title":"Dr.","email":null,"phone":"+3663481048","profile_url":"https://szeged.imami.hu/hazi-gyermekorvosok/dr-gali-ida","confidence":0.91,"bio":"Iskolaorvosi szolgálat: Fő utcai \"Platánfa\" Óvoda; Dohánysori \"Kippkopp\" Óvoda; Széchenyi úti Óvoda; Gróf Széchenyi István Általános Iskola, Átmeneti- és Diákotthon."}]