{"schema_version":1,"clinic":{"id":"099f61cf-93f8-45fa-a48e-19bdd6125f90","name":"Dr. Szilágyi Annamária — háziorvosi praxis","legal_name":"Dr. Szilágyi Annamária és Társa Bt.","registry_id":"040090019","country":"HU","city":"Békéscsaba","region":"BÉKÉS","postal_code":"5600","address":"5600, Békéscsaba, Árpád sor 6.","phone":"+3666321321","website":"http://szilagyihaziorvos.hu/","domain":"szilagyihaziorvos.hu","official_website":null,"official_domain":null,"official_website_confidence":0.0,"clinic_type":"primary_care","funding":"unknown","lead_score":38,"contactability_score":0,"data_quality_score":45,"scrape_difficulty_score":58,"source_coverage_status":"supporting_actionable","identity_status":"registry_seeded","identity_confidence":0.95,"outreach_eligibility":"suppressed"},"state":{"clinic_id":"099f61cf-93f8-45fa-a48e-19bdd6125f90","status":"needs_review","version":0},"machine_status":"no_candidate","candidates":[],"professionals":[{"id":"97d1ea9e-352e-427b-9d25-41afa5becb32","name":"Bólya Andrea","role":"district_nurse","raw_title":"körzeti nővér","email":null,"phone":null,"profile_url":"http://szilagyihaziorvos.hu/rolunk/","confidence":0.95,"bio":"1990-ben általános szakápolóként végzett. 1995-ben szülésznői szakképesítést szerzett, 2005-ben E-kategóriás szakápoló lett. 1990-2005 között a békéscsabai Réthy Pál Kórházban dolgozott a Szülészet-Nőgyógyászati, majd az Ortopédiai Osztályon. 2006-2014 között Békésen dolgozott háziorvos mellett körzeti nővérként. A 6-os számú Felnőtt Körzet betegeit 2014 óta segíti."},{"id":"a8daceef-d9b0-489a-89f9-b7d590ba4853","name":"Sóváriné Hajdu Erika","role":"district_nurse","raw_title":"körzeti nővér","email":null,"phone":null,"profile_url":"http://szilagyihaziorvos.hu/rolunk/","confidence":0.9,"bio":"1989 óta dolgozik az egészségügyben. 1992-ben gyógyszertári asszisztensként végzett, 2002-ben gyógyszerellátási szakasszisztens lett. 1989-1993 között a Réthy Pál Kórház Intézeti Gyógyszertárában dolgozott, 2000-2021 között ugyanott szakasszisztens volt, 2021-2026 között háziorvosi körzetekben dolgozott nővérként. A 6-os számú Felnőtt Körzet személyzetéhez 2026. június 1. óta tartozik."},{"id":"5d05591e-00a3-41d7-b41d-7e86fc15ba28","name":"Dr. Szilágyi Annamária","role":"doctor","raw_title":"Dr.","email":null,"phone":null,"profile_url":null,"confidence":0.79,"bio":null},{"id":"7317a2d7-2659-4926-82c1-be9c26827efd","name":"Dr. Szilágyi Annamária","role":"general_practitioner","raw_title":"háziorvos","email":null,"phone":null,"profile_url":"http://szilagyihaziorvos.hu/rolunk/","confidence":0.98,"bio":"1991-ben érettségizett a békéscsabai Rózsa Ferenc Gimnáziumban. Orvosi tanulmányait 1991-1997 között Szegeden, a Szent-Györgyi Albert Orvostudományi Egyetem Általános Orvostudományi Karán végezte. A diplomaszerzés után a békéscsabai Réthy Pál Kórház Ortopédiai Osztályán dolgozott. 1996-2001 között az Országos Mentőszolgálatnál mentőtiszt, illetve mentőorvos volt. 2002-ben ortopédiai, 2014-ben háziorvosi szakvizsgát tett. 2014. március 1. óta a békéscsabai 6-os számú felnőtt háziorvosi körzetben dolgozik."},{"id":"9bf7bc19-4e05-49d2-a290-8060efb90b7d","name":"Bólya Andrea","role":"registered_nurse","raw_title":"körzeti nővér","email":null,"phone":null,"profile_url":null,"confidence":0.95,"bio":"1990-ben általános szakápolóként végzett, 1995-ben szülésznői szakképesítést szerzett, 2005-ben E-kategóriás szakápoló lett. 1990-2005 között a békéscsabai Réthy Pál Kórházban dolgozott, 2006-2014 között Békésen háziorvos mellett körzeti nővérként. A 6-os számú felnőtt körzet betegeit 2014 óta segíti."},{"id":"f978c2f9-862e-4cfd-9a6e-8f1e0f314373","name":"Sóváriné Hajdu Erika","role":"registered_nurse","raw_title":"körzeti nővér","email":null,"phone":null,"profile_url":null,"confidence":0.91,"bio":"1989 óta dolgozik az egészségügyben. 1992-ben gyógyszertári asszisztensként végzett, 2002-ben gyógyszerellátási szakasszisztens lett. 1989-1993 között a Réthy Pál Kórház intézeti gyógyszertárában dolgozott, 2000